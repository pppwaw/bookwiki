DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
OPENROUTER_API_KEY=
VERTEX_PROJECT=
VERTEX_LOCATION=
BOOKWIKI_LANGSMITH_TRACING=false
BOOKWIKI_CACHE_DIR=work/.cache
BOOKWIKI_SITE_PORT=3000
BOOKWIKI_TEST_LLM=
BOOKWIKI_CHAT_API_KEY=
BOOKWIKI_CHAT_BASE_URL=https://openrouter.ai/api/v1
BOOKWIKI_CHAT_MODEL=google/gemma-4-31b-it
# 允许学生在 AI Chat 里贴图提问(1/true/yes 开启)。仅当配置的模型支持视觉输入时开启。
BOOKWIKI_CHAT_VISION=
# 站内搜索语义 embedding(构建期与查询期必须一致;留空则只建中文关键词索引)
BOOKWIKI_EMBED_MODEL=baai/bge-m3
BOOKWIKI_EMBED_BASE_URL=https://openrouter.ai/api/v1
MINERU_BACKEND=local
MINERU_API_URL=http://127.0.0.1:8000
MINERU_CLOUD_API_URL=https://mineru.net
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_API_TIMEOUT_SECONDS=1800
MINERU_API_POLL_DEADLINE_SECONDS=7200
MINERU_API_POLL_INTERVAL_SECONDS=2
